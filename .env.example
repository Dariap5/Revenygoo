# --- Supabase (https://supabase.com/dashboard) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Любой из двух (в Dashboard → API): legacy anon (jwt) или новый Publishable (sb_publishable_…)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-only: never expose to the browser (Route Handlers / server actions only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Публичный URL приложения (ссылки сброса пароля). Локально: http://localhost:3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend: письма со ссылкой сброса пароля (Route POST /api/auth/forgot-password)
# RESEND_API_KEY=re_...
# FROM_EMAIL=onboarding@yourdomain.com

# Демо-вход без формы (signInWithPassword в браузере). По умолчанию demo@revenygo.local / demo (миграция auth_demo_user).
# NEXT_PUBLIC_DEMO_USER_EMAIL=demo@revenygo.local
# NEXT_PUBLIC_DEMO_USER_PASSWORD=demo
#
# Авто-создание демо-пользователя и org через Admin API при неудачном входе (только для демо; нужен service role).
# DEMO_AUTO_PROVISION=true
# NEXT_PUBLIC_DEMO_AUTO_PROVISION=true

# LLM: если в org_settings нет провайдера/ключа, подставляются эти значения (иначе POST чата — 503).
# LLM_DEFAULT_PROVIDER=openai
# LLM_DEFAULT_API_KEY=sk-...
#
# OpenRouter / OpenAI-совместимый шлюз (routerai.ru и т.д.):
# LLM_PROVIDER=openrouter
# LLM_API_KEY=...
# LLM_BASE_URL=https://routerai.ru/api/v1
# LLM_MODEL=google/gemma-4-26b-a4b-it
#
# Шифрование API-ключей в /admin/models (openssl rand -hex 32):
# LLM_SETTINGS_ENCRYPTION_KEY=...

